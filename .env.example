# Web3Forms access key for the contact form (https://web3forms.com).
# Submissions are delivered to the email tied to the access key.
# NEXT_PUBLIC_* — publishable key, not a secret. Lock it down in the
# Web3Forms dashboard by setting allowed domains.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Public CDN bucket that hosts the hero video and bg image
# (cdt-homepage/cdt-demo-home.mp4, home-bg.png).
# NEXT_PUBLIC_* because the URL is read client-side. The bucket itself is public.
NEXT_PUBLIC_MINIO_BUCKET_URL=
