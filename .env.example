# Web3Forms access key for the contact form.
# Sign up at https://web3forms.com, create an access key tied to info@collabdt.org,
# and add `collabdigitaltwins.github.io` to your allowed domains. Submissions arrive
# at the email tied to the access key.
#
# This is NEXT_PUBLIC_* on purpose — it's a public key, abuse is throttled by domain
# allowlist + per-IP rate limits on Web3Forms' side, not by hiding the key.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Public CDN bucket that hosts the hero video and bg image (cdt-homepage/cdt-demo-home.mp4, home-bg.png).
# Server-side only (NOT NEXT_PUBLIC_*) so the URL is not inlined into the client bundle.
# The bucket itself is public; the URL is read in src/app/page.tsx and passed through props.
MINIO_BUCKET_URL=
